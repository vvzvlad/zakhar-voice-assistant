# --- Credentials (required, no default in code) ---
GROQ_API_KEY=your_groq_api_key_here
WEATHER_API_KEY=your_openweathermap_api_key_here

# --- Our own services (required, no default in code) ---
# Node-RED MCP server endpoint (node-red-contrib-mcp-server) on :8001/mcp
MCP_SMARTHOME_URL=http://10.0.0.5:8001/mcp
# Optional bearer token for the MCP server (empty = no auth header)
# MCP_SMARTHOME_TOKEN=
# home_assistant_tts service base
TTS_BASE_URL=http://10.0.0.5:8124
# Base URL the speakers use to fetch generated audio
PUBLIC_BASE_URL=http://10.0.0.10:8200

# --- ESPHome speakers (required) ---
# Devices separated by ';', fields by '|':  name|host|psk;name2|host2|psk2
ESPHOME_DEVICES=living|10.0.0.5|psk_here

# --- Non-secret config (defaults in code, override if needed) ---
# ESPHOME_PORT=6053
# GROQ_MODEL=openai/gpt-oss-120b
# GROQ_STT_MODEL=whisper-large-v3-turbo
# SOCKS/HTTP proxy for Groq + weather; empty = direct
# GROQ_PROXY=
# WEATHER_CITY=Moscow
# STT backend: groq (cloud Whisper) | vosk (in-process, needs `make models`)
# STT_BACKEND=groq
# VOSK_MODEL_PATH=models/vosk-model-small-ru-0.22
# TTS backend: teratts (HTTP service) | piper (in-process, needs `make models`)
# TTS_BACKEND=teratts
# Piper voice onnx path; the config json is expected at <path>.json
# PIPER_VOICE_PATH=models/ru_RU-ruslan-medium.onnx
# Seconds of silence inserted between sentences (Piper)
# TTS_SENTENCE_SILENCE=0.4
# TTS_TIMEOUT=30
# AUDIO_HOST=0.0.0.0
# AUDIO_PORT=8200
# AUDIO_TTL=300
# LOG_LEVEL=INFO
# SYSTEM_PROMPT_PATH=data/system_prompt.md
# CONTEXT_DIR=data
# Recent user+assistant exchanges kept and shown to the model
# CONTEXT_MAX_TURNS=5
# Idle seconds after which a conversation resets to empty
# CONTEXT_TTL_SECONDS=300

# --- Server-side VAD end-pointing (defaults in code, override if needed) ---
# webrtcvad aggressiveness 0..3 (higher = more aggressive filtering of non-speech)
# VAD_AGGRESSIVENESS=2
# Trailing silence (ms) after speech that ends the utterance
# VAD_SILENCE_MS=800
# Minimum speech (ms) before end-detection arms
# VAD_MIN_SPEECH_MS=200
# Hard cap (ms): finalize even without trailing silence
# VAD_MAX_UTTERANCE_MS=15000
# If no speech is detected at all after start, finalize after this (ms)
# VAD_NO_SPEECH_TIMEOUT_MS=8000
